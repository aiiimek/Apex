<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane
    prefHeight="700.0"
    prefWidth="1200.0"
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.apex.app.ui.MainController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="top-panel" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="14.0" left="20.0" right="20.0" top="14.0" />
            </padding>

            <ComboBox
                fx:id="profileComboBox"
                promptText="%field.host.prompt"
                styleClass="combo-box, top-bar-control"
                HBox.hgrow="SOMETIMES"
                minWidth="180.0"
                maxWidth="280.0" />
            <Button
                text="%btn.save"
                onAction="#handleSaveProfile"
                styleClass="button, top-bar-control" />
            <Button
                text="%btn.manage"
                onAction="#handleManageProfiles"
                styleClass="button, top-bar-control" />

            <Separator orientation="VERTICAL" />

            <Label fx:id="statusLabel" text="%label.no_sessions" styleClass="status-label" />

            <Region HBox.hgrow="ALWAYS" />

            <TextField
                fx:id="hostField"
                promptText="%field.host.prompt"
                styleClass="text-field"
                HBox.hgrow="SOMETIMES"
                minWidth="140.0"
                maxWidth="220.0" />
            <TextField
                fx:id="portField"
                promptText="%field.port.prompt"
                text="22"
                styleClass="text-field"
                minWidth="50.0"
                maxWidth="70.0" />
            <TextField
                fx:id="userField"
                promptText="%field.username.prompt"
                styleClass="text-field"
                HBox.hgrow="SOMETIMES"
                minWidth="100.0"
                maxWidth="160.0" />
            <PasswordField
                fx:id="passwordField"
                promptText="%field.password.prompt"
                styleClass="password-field"
                HBox.hgrow="SOMETIMES"
                minWidth="110.0"
                maxWidth="180.0" />

            <Button
                fx:id="connectButton"
                text="%btn.connect"
                onAction="#handleConnect"
                styleClass="button, connect-button, top-bar-control" />

            <Separator orientation="VERTICAL" />

            <Label text="%label.language" styleClass="status-label" />
            <ComboBox
                fx:id="languageComboBox"
                styleClass="combo-box, top-bar-control, small-combo"
                minWidth="90.0"
                onAction="#handleLanguageChange" />
        </HBox>
    </top>

    <center>
        <TabPane
            fx:id="mainTabPane"
            tabClosingPolicy="ALL_TABS"
            styleClass="session-tab-pane"
            BorderPane.alignment="CENTER">
        </TabPane>
    </center>

    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT">
            <padding>
                <Insets top="5" bottom="5" left="20" right="20" />
            </padding>
            <Label fx:id="pathLabel" text="" styleClass="status-bar-label" />
        </HBox>
    </bottom>
</BorderPane>
